# Spotify OAuth (standard Authorization Code flow — NOT PKCE)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Redirect URI registered in your Spotify app dashboard
# For local dev: http://localhost:3001/auth/spotify/callback
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/spotify/callback

# BPM endpoint shared secret (sent as X-BPM-Key header from Garmin watch)
# Generate with: openssl rand -hex 32
BPM_API_KEY=your_bpm_api_key_here

# Database (SQLite for v1; switch provider + URL for PostgreSQL/Supabase in vnext)
DATABASE_URL="file:./prisma/dev.db"

# Server port (default: 3001)
PORT=3001

# React client origin for CORS (default: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# ngrok tunnel URL (required for Android CIQ makeWebRequest — must be HTTPS)
NGROK_URL=https://your-ngrok-subdomain.ngrok.io
