<?xml version="1.0"?>
<!--
  Heart Beater MC — Connect IQ Manifest
  App type: DataField (reads Activity.Info.currentHeartRate during workouts)

  MANUAL BUILD REQUIRED:
    Claude Code cannot compile Monkey C. Use the Garmin Connect IQ SDK:
      monkeyc -f monkey.jungle -o bin/HeartBeaterApp.prg -d <device-id> -y developer_key.der
    Then sideload via Garmin Express or Garmin Connect app.
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
  <iq:application
    entry="HeartBeaterApp"
    id="a3d4b5c6-e7f8-9012-abcd-ef1234567890"
    launcherIcon="@Drawables.LauncherIcon"
    minSdkVersion="3.2.0"
    name="@Strings.AppName"
    type="dataField"
    version="1.0.0">

    <iq:products>
      <!-- Common Garmin watches — add your specific model if not listed -->
      <iq:product id="fenix6"/>
      <iq:product id="fenix6pro"/>
      <iq:product id="fenix6s"/>
      <iq:product id="fenix7"/>
      <iq:product id="fenix7pro"/>
      <iq:product id="fenix7s"/>
      <iq:product id="fenix7x"/>
      <iq:product id="forerunner245"/>
      <iq:product id="forerunner255"/>
      <iq:product id="forerunner265"/>
      <iq:product id="forerunner745"/>
      <iq:product id="forerunner945"/>
      <iq:product id="forerunner955"/>
      <iq:product id="vivoactive4"/>
      <iq:product id="vivoactive4s"/>
    </iq:products>

    <iq:permissions>
      <!-- Required for Communications.makeWebRequest() -->
      <iq:uses-permission id="Communications"/>
      <!-- Required for Activity.Info.currentHeartRate -->
      <iq:uses-permission id="FitContributor"/>
      <!-- Required for background heart rate access -->
      <iq:uses-permission id="Sensor"/>
    </iq:permissions>

    <iq:languages>
      <iq:language id="eng"/>
    </iq:languages>

  </iq:application>
</iq:manifest>
